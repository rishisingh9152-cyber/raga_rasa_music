# RagaRasa Backend Configuration
# Copy this to .env and customize for your environment

# ===========================
# API Settings
# ===========================

# API host and port
API_HOST=0.0.0.0
API_PORT=8000

# ===========================
# Database Configuration
# ===========================

# MongoDB connection URL
# Local: mongodb://localhost:27017
# MongoDB Atlas: mongodb+srv://user:password@cluster.mongodb.net/
MONGODB_URL=mongodb://localhost:27017

# Database name
DATABASE_NAME=raga_rasa

# ===========================
# Redis Cache Configuration
# ===========================

# Redis connection URL
# Local: redis://localhost:6379
# Redis Cloud: redis://user:password@host:port
REDIS_URL=redis://localhost:6379

# Cache expiry time in seconds (default: 1 hour)
REDIS_CACHE_EXPIRY=3600

# ===========================
# Machine Learning Models
# ===========================

# Emotion detection model
# Options: 'fer' (Facial Expression Recognition) or 'deepface'
EMOTION_MODEL=fer

# Confidence threshold for emotion detection (0.0 - 1.0)
# If confidence below threshold, default to 'Neutral'
EMOTION_CONFIDENCE_THRESHOLD=0.3

# ===========================
# Recommendation Engine
# ===========================

# Maximum number of songs to recommend per request
MAX_RECOMMENDATIONS=5

# Embedding dimension for vector search (FAISS)
EMBEDDING_DIMENSION=128

# ===========================
# Celery Task Queue
# ===========================

# Celery broker (uses Redis)
CELERY_BROKER=redis://localhost:6379

# Celery result backend (uses Redis)
CELERY_BACKEND=redis://localhost:6379

# ===========================
# Audio Processing
# ===========================

# Directory to store uploaded audio files
AUDIO_UPLOAD_DIR=./audio

# Maximum audio file size in MB
MAX_AUDIO_SIZE_MB=50

# ===========================
# Environment & Debugging
# ===========================

# Debug mode (set to False in production)
DEBUG=False

# ===========================
# CORS Configuration
# ===========================

# Allowed CORS origins (comma-separated)
# Leave as * for development, specify in production
CORS_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:3000

# ===========================
# Production Settings (if deploying)
# ===========================

# Set to True for production
# PRODUCTION=False

# Secret key for JWT tokens (if using authentication)
# SECRET_KEY=your-secret-key-here

# ===========================
# Logging
# ===========================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file (empty = console only)
# LOG_FILE=logs/backend.log

# ===========================
# Notes
# ===========================

# For local development:
# 1. Ensure MongoDB is running on localhost:27017
# 2. Ensure Redis is running on localhost:6379
# 3. Run: python main.py

# For Docker Compose:
# 1. Run: docker-compose up
# 2. All services start automatically

# For production deployment:
# 1. Update MONGODB_URL to production MongoDB
# 2. Update REDIS_URL to production Redis
# 3. Set DEBUG=False
# 4. Configure CORS_ORIGINS with actual domain
# 5. Set proper SECRET_KEY if using authentication
