# Backend Environment Configuration
# Copy this to .env and customize for your environment

# ===========================
# API Settings
# ===========================

# API host and port (leave as-is for production)
API_HOST=0.0.0.0
API_PORT=8000

# ===========================
# Database Configuration
# ===========================

# MongoDB Atlas Connection URL
# Format: mongodb+srv://username:password@cluster.mongodb.net/?appName=AppName
MONGODB_URL=mongodb+srv://Rishi123:Rishi_123@majorproject.lpwzhzc.mongodb.net/?appName=MajorProject

# Database name
DATABASE_NAME=raga_rasa

# ===========================
# Emotion Recognition Service
# ===========================

# External emotion recognition service URL (from HF Spaces or other provider)
# Example: https://username-raga-rasa-emotion.hf.space
EMOTION_SERVICE_URL=http://localhost:5000

# ===========================
# JWT Authentication
# ===========================

# Secret key for JWT tokens (MUST be set in production!)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change-me-in-production-use-env-variable

# JWT Algorithm (default: HS256)
# JWT_ALGORITHM=HS256

# JWT Token expiration in hours
# JWT_EXPIRATION_HOURS=24

# ===========================
# CORS Configuration
# ===========================

# Comma-separated list of allowed origins
# Include both local development and production URLs
# The regex pattern in middleware handles *.vercel.app automatically
ALLOWED_ORIGINS_STR=https://raga-rasa-music-52.vercel.app,http://localhost:5173,http://localhost:8080

# ===========================
# Cloud Storage (Cloudinary)
# ===========================

# Optional: Only set if using Cloudinary for audio/image storage
CLOUDINARY_CLOUD_NAME=dlx3ufj3t
CLOUDINARY_API_KEY=255318353319693
CLOUDINARY_API_SECRET=MKFvdiyfmNpzxbaGKBMFM6SlT2c

# ===========================
# Cache Configuration (Optional)
# ===========================

# Redis URL for caching (optional, leave empty if not using)
# Example: redis://localhost:6379
REDIS_URL=

# Cache expiry time in seconds (default: 3600 = 1 hour)
# REDIS_CACHE_EXPIRY=3600

# ===========================
# Debugging
# ===========================

# Enable debug mode (set to False in production)
DEBUG=False

# ===========================
# IMPORTANT NOTES
# ===========================

# For Local Development:
# 1. Use localhost URLs
# 2. Keep DEBUG=False to test production behavior
# 3. Ensure MONGODB_URL points to your Atlas cluster

# For Production (Koyeb/Render):
# 1. Generate new JWT_SECRET_KEY: python -c "import secrets; print(secrets.token_urlsafe(32))"
# 2. Set EMOTION_SERVICE_URL to your HF Spaces URL
# 3. Keep DEBUG=False
# 4. Ensure ALLOWED_ORIGINS_STR is set correctly
# 5. All other env vars should be set in the deployment platform

# For Testing CORS:
# - Backend uses CustomCORSMiddleware with regex pattern matching
# - Supports both specific origins (localhost) and wildcard patterns (*.vercel.app)
# - All CORS headers are properly set in responses
